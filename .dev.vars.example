# Copy this file to .dev.vars for local Wrangler testing.
# Never commit real secret values.

ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

SITE_URL=https://ptgactivewear.co.nz

# Local catalogue and admin settings. Production stays static until the D1 cutover is approved.
CATALOG_SOURCE=d1
INVENTORY_ENFORCEMENT=d1
CHECKOUT_ENABLED=true
LOW_STOCK_THRESHOLD=5
ENVIRONMENT=development

# Stripe test-mode keys only while testing.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Existing email provider.
EMAIL_PROVIDER=resend
EMAIL_API_KEY=re_replace_me
CONTACT_TO_EMAIL=info@ptgactivewear.co.nz
CONTACT_FROM_EMAIL=info@ptgactivewear.co.nz

# PRODUCT_IMAGES is an R2 binding configured in wrangler.jsonc, not a secret or text variable.
