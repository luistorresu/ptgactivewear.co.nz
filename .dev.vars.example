# Copy this file to .dev.vars for local Wrangler testing.
# Never commit real secret values.

ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

SITE_URL=https://ptgactivewear.co.nz

# Local catalogue and admin settings. Production stays static until the D1 cutover is approved.
CATALOG_SOURCE=d1
INVENTORY_ENFORCEMENT=d1
CHECKOUT_ENABLED=true
PICKUP_ENABLED=true
PICKUP_LABEL=Pick up from Training Centre
PICKUP_PRICE_CENTS=0
PICKUP_LOCATION_NAME=Training Centre
PICKUP_ADDRESS_LINE_1=
PICKUP_ADDRESS_LINE_2=
PICKUP_CITY=
PICKUP_POSTCODE=
PICKUP_INSTRUCTIONS=We will contact you when your order is ready to collect and confirm the collection details.
NZ_DELIVERY_ENABLED=true
NZ_DELIVERY_LABEL=New Zealand Delivery
NZ_DELIVERY_PRICE_CENTS=500
NZ_DELIVERY_COUNTRY=NZ
PAYMENT_SURCHARGE_ENABLED=false
PAYMENT_SURCHARGE_PERCENT=2.65
PAYMENT_SURCHARGE_FIXED_CENTS=30
PAYMENT_SURCHARGE_LABEL=Card processing surcharge
PAYMENT_SURCHARGE_DESCRIPTION=This surcharge helps cover card payment processing costs.
LOW_STOCK_THRESHOLD=5
ENVIRONMENT=development

# Stripe test-mode keys only while testing.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Existing email provider.
EMAIL_PROVIDER=resend
EMAIL_API_KEY=re_replace_me
CONTACT_TO_EMAIL=info@ptgactivewear.co.nz
CONTACT_FROM_EMAIL=info@ptgactivewear.co.nz

# PRODUCT_IMAGES is an R2 binding configured in wrangler.jsonc, not a secret or text variable.
